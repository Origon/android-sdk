<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/origon_screen_background">

    <!-- ── Ready state: drawer + chat ──────────────────────────────── -->
    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawer_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Main content: chat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/origon_screen_background"
            android:orientation="vertical">

            <!-- Toolbar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="12dp">

                <ImageButton
                    android:id="@+id/btn_history"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_session_history"
                    android:src="@drawable/ic_history"
                    app:tint="@color/origon_text_primary" />

                <ImageButton
                    android:id="@+id/btn_new_session"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_new_session"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/origon_text_primary" />
            </FrameLayout>

            <!-- Messages / empty state -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/messages_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" />

                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        android:contentDescription="@string/app_name"
                        android:src="@drawable/ic_origon_logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chat_empty_greeting"
                        android:textColor="@color/origon_text_primary"
                        android:textSize="22sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Composer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/bg_composer"
                android:orientation="vertical"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/pending_list"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:paddingHorizontal="6dp"
                    android:paddingTop="6dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_attach"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/attach_files"
                        android:src="@drawable/ic_paperclip"
                        app:tint="@color/origon_text_secondary" />

                    <EditText
                        android:id="@+id/input_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/chat_input_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="5"
                        android:paddingVertical="8dp"
                        android:textColor="@color/origon_text_primary"
                        android:textColorHint="@color/origon_text_tertiary"
                        android:textSize="16sp"
                        android:importantForAutofill="no" />

                    <FrameLayout
                        android:id="@+id/btn_send"
                        android:layout_width="40dp"
                        android:layout_height="40dp">

                        <View
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_accent" />

                        <ImageView
                            android:id="@+id/send_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_voice"
                            app:tint="@color/white" />

                        <ProgressBar
                            android:id="@+id/send_progress"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/white"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sidebar drawer -->
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@color/origon_screen_background"
            android:fitsSystemWindows="true"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="28dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_origon_wordmark"
                app:tint="@color/origon_text_primary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sessions_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp" />

            <ImageButton
                android:id="@+id/btn_options"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sidebar_options"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/origon_text_secondary" />
        </LinearLayout>
    </androidx.drawerlayout.widget.DrawerLayout>

    <!-- ── Loading state ───────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/loading_logo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_origon_logo" />

    <!-- ── Error state ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/error_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/origon_text_secondary"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/btn_retry"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_primary">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/retry"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/btn_change_endpoint_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:text="@string/sidebar_change_endpoint"
            android:textColor="@color/origon_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- ── Call overlay ────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/call_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Floating toast -->
    <TextView
        android:id="@+id/toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="96dp"
        android:background="@drawable/bg_toast"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textColor="@color/origon_toast_foreground"
        android:textSize="14sp"
        android:visibility="gone" />
</FrameLayout>
