<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Accent — adaptive monochrome: black in light mode, white in dark mode.
         Content on top of accent should use origon_accent_foreground (the
         inverse), NOT a fixed white. -->
    <color name="origon_accent">#000000</color>
    <!-- Foreground for content sitting on top of accent: white in light mode. -->
    <color name="origon_accent_foreground">#FFFFFF</color>

    <!-- Light-mode palette (mirrors iOS system-adaptive colors). -->
    <color name="origon_screen_background">#FFFFFF</color>
    <color name="origon_surface">#F2F2F7</color>
    <color name="origon_text_primary">#000000</color>
    <color name="origon_text_secondary">#99000000</color>
    <color name="origon_text_tertiary">#4D000000</color>
    <color name="origon_remote_bubble">#E5E5EA</color>
    <!-- Self-user message bubble: black @ 6%. Subtle tint rather than the
         accent, so text on top uses origon_text_primary. -->
    <color name="origon_self_bubble">#0F000000</color>
    <color name="origon_border">#C6C6C8</color>
    <color name="origon_error">#FF3B30</color>
    <color name="origon_toast_background">#333333</color>
    <color name="origon_toast_foreground">#FFFFFF</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>

    <!-- Adaptive launcher-icon background (does not switch day/night). -->
    <color name="ic_launcher_background">#111111</color>
</resources>
